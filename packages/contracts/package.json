{
  "name": "@detroitlabs/figmint-contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./schemas/ops-program.v1": "./dist/ops-program.v1.schema.json",
    "./schemas/tokens.v1": "./dist/tokens.v1.schema.json",
    "./schemas/tokens.v1.w3c-dtcg": "./dist/tokens.v1.w3c-dtcg.schema.json",
    "./schemas/tokens.v1.legacy": "./dist/tokens.v1.legacy.schema.json",
    "./schemas/tokens.v1.input": "./dist/tokens.v1.input.schema.json",
    "./schemas/component-spec.v1": "./dist/component-spec.v1.schema.json",
    "./schemas/drift-report.v1": "./dist/drift-report.v1.schema.json",
    "./schemas/handoff-context.v1": "./dist/handoff-context.v1.schema.json",
    "./schemas/registry.v1": "./dist/registry.v1.schema.json"
  },
  "scripts": {
    "build:types": "tsc --emitDeclarationOnly",
    "build:schemas": "node scripts/build-schemas.mjs",
    "build": "npm run build:types && npm run build:schemas",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "ts-json-schema-generator": "~2.9.0",
    "typescript": "^6.0.3"
  }
}
