{
  "v": 1,
  "kind": "component-spec",
  "name": "Button",
  "framework": "react",
  "category": "Form & Input",
  "archetype": "chip",
  "variantMatrix": {
    "variant": ["default", "destructive", "outline", "secondary", "ghost", "link"],
    "size": ["sm", "default", "lg", "icon"]
  },
  "props": [
    {
      "name": "variant",
      "type": "enum",
      "default": "default",
      "enum": ["default", "destructive", "outline", "secondary", "ghost", "link"]
    },
    {
      "name": "size",
      "type": "enum",
      "default": "default",
      "enum": ["sm", "default", "lg", "icon"]
    },
    { "name": "disabled", "type": "boolean", "default": false },
    { "name": "asChild", "type": "boolean", "default": false },
    {
      "name": "type",
      "type": "enum",
      "default": "button",
      "enum": ["button", "submit", "reset"]
    },
    { "name": "className", "type": "string", "default": "" }
  ],
  "bindings": [
    { "selector": "root.fill", "variable": "color/primary/default" },
    { "selector": "text/label.text-style", "variable": "Label/MD" }
  ],
  "layout": {
    "direction": "horizontal",
    "gap": "space/md",
    "padding": "space/md",
    "sizing": {
      "horizontal": "hug",
      "vertical": "hug"
    }
  },
  "confidence": {
    "layout": "high",
    "bindings": "medium",
    "unresolved": ["trailing icon slot"]
  }
}
