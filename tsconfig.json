{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "paths": {
      "@/*": ["./src/*"],
      "@/config/flags": ["./src/config/flags.community.ts"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "packages/contracts/src/**/*"],
  "exclude": ["dist", "node_modules"]
}
