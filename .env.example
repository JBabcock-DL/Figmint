# Copy to `.env.local` and fill in your values (`.env.local` is gitignored).
#
# GitHub OAuth App — Device Flow (WO-016)
# Register: GitHub → Settings → Developer settings → OAuth apps
# Enable "Device Flow" on the app. Only client_id goes in the plugin bundle — never client_secret.
GITHUB_OAUTH_CLIENT_ID=

# Optional — production OAuth relay URL (sets manifest allowedDomains at build time)
# FIGMINT_OAUTH_RELAY_URL=https://oauth-relay.yourdomain.com
