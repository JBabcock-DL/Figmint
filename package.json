{
  "name": "figmint",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "build:community": "node scripts/build-community.mjs",
    "build:org": "node scripts/build-org.mjs",
    "dev": "node scripts/dev.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@detroitlabs/figmint-contracts": "workspace:*",
    "@figma/plugin-typings": "^1.127.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.4",
    "@types/node": "^22.15.29"
  }
}
